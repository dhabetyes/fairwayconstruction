# Password-protect the storm leads tool (internal use only)
AuthType Basic
AuthName "Fairway Construction — Internal Tools"
AuthUserFile /home/.htpasswd
Require valid-user

# Prevent directory listing
Options -Indexes

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
</IfModule>
